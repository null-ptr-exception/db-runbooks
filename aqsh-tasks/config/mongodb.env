# Deploy-time configuration for MongoDB tasks.
# Mounted into aqsh at /etc/aqsh/config/mongodb.env via ConfigMap.
# Scripts source this file for environment-specific settings.

MINIO_ENDPOINT=http://minio.minio.svc.cluster.local:9000

# Deployment-convention defaults for recovery/account/sanity-check/restart
# tasks. A task-input value always wins when a caller explicitly passes one;
# these are the fallback used by everyone else in this cluster. See
# CLAUDE.md "Configuration Layers" for the precedence rule.
# MONGO_STS_NAME_DEFAULT=mongodb
# MONGO_CRED_SECRET_DEFAULT=mongodb-credentials
# MONGO_CRED_USER_KEY_DEFAULT=MONGO_ROOT_USER
# MONGO_CRED_PASS_KEY_DEFAULT=MONGO_ROOT_PASS
# MONGO_CRED_USER_DEFAULT=
# RECOVERY_CONFIGMAP_DEFAULT=mongodb-recovery-config
# RECOVERY_DATA_PATH_DEFAULT=/bitnami/mongodb/data/db
# RECOVERY_MOUNT_PATH_DEFAULT=/bitnami/mongodb

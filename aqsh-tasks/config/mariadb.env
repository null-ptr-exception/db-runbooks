# Deploy-time configuration for MariaDB tasks.
# Mounted into aqsh at /etc/aqsh/config/mariadb.env via ConfigMap.
# Scripts source this file for environment-specific settings.

MINIO_ENDPOINT=http://minio.minio.svc.cluster.local:9000

# CRD apiGroup of the mariadb-operator generation on this cluster. Normally
# auto-detected through Kubernetes API discovery (the group serving the
# `mariadbs` resource), so this stays commented. Set it explicitly only for an
# unusual fork whose group cannot be confidently detected. Default when
# unset/undetectable: k8s.mariadb.com.
# MARIADB_OPERATOR_GROUP_DEFAULT=k8s.mariadb.com

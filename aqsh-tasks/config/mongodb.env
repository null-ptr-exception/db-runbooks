# Deploy-time configuration for MongoDB tasks.
# Mounted into aqsh at /etc/aqsh/config/mongodb.env via ConfigMap.
# Scripts source this file for environment-specific settings.

MINIO_ENDPOINT=http://minio.minio.svc.cluster.local:9000

# Deployment-convention defaults for recovery/account/sanity-check/restart/
# reconfig/fcv tasks. A task-input value always wins when a caller explicitly
# passes one (recovery/reconfig/fcv tasks have no task-input tier — for them
# these sit ahead of live-cluster auto-detect); these are the fallback used
# by everyone else in this cluster. See CLAUDE.md "Configuration Layers" for
# the precedence rule.
# MONGO_STS_NAME_DEFAULT=mongodb
# MONGO_HEADLESS_SVC_DEFAULT=          # headless Service for pod seed FQDNs; default: live spec.serviceName detect, then sts_name
# MONGO_CRED_SECRET_DEFAULT=mongodb-credentials
# MONGO_CRED_USER_KEY_DEFAULT=MONGO_ROOT_USER
# MONGO_CRED_PASS_KEY_DEFAULT=MONGO_ROOT_PASS
# MONGO_CRED_USER_DEFAULT=
# RECOVERY_CONFIGMAP_DEFAULT=mongodb-recovery-config
# RECOVERY_DATA_PATH_DEFAULT=/bitnami/mongodb/data/db
# RECOVERY_MOUNT_PATH_DEFAULT=/bitnami/mongodb

# Reconfig gateway policy knobs (docs/mongodb/reconfig.md). Per-deployment
# policy, not task inputs.
# RECONFIG_AUDIT_CONFIGMAP_DEFAULT=mongodb-reconfig-audit
# RECONFIG_DR_MIN_UNREACHABLE_SECONDS_DEFAULT=300
# RECONFIG_LAG_WARN_SECONDS_DEFAULT=60
# RECONFIG_AUDIT_MAX_ENTRIES_DEFAULT=20

# PBM gateway (docs/mongodb/pbm.md). All optional — the tasks resolve
# internal config -> live auto-detect -> convention literal. Storage
# location/credentials are infra, never task inputs; re-point storage by
# changing these and running pbm/config (dry_run -> confirm).
# PBM_AGENT_CONTAINER_DEFAULT=pbm-agent
# PBM_S3_CREDENTIALS_SECRET_DEFAULT=minio
# PBM_S3_BUCKET_DEFAULT=db-backups
# PBM_S3_PREFIX_DEFAULT=            # default: mongodb/<namespace>
# PBM_S3_ENDPOINT_DEFAULT=          # default: MINIO_ENDPOINT
# PBM_S3_REGION_DEFAULT=us-east-1
# PBM_SCHEDULE_CRONJOB_DEFAULT=pbm-backup-schedule
# PBM_SCHEDULE_AQSH_URL_DEFAULT=    # default: http://aqsh.mongo-core.svc.cluster.local:4180
# LOG_LEVEL_DEFAULT=INFO            # baseline task log verbosity (log_level input overrides per call)
